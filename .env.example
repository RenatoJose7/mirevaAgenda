NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=SUA_CHAVE_PUBLICA_DO_SUPABASE
# Opcional/compatibilidade: se voce estiver usando a chave anon legada, pode usar esta variavel.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANON_PUBLICA_DO_SUPABASE

# Server-side only. Nunca prefixar com NEXT_PUBLIC_ e nunca usar em componente client.
SUPABASE_SERVICE_ROLE_KEY=SUA_CHAVE_SECRETA_APENAS_SERVER_SIDE

# Pagamentos - Asaas. Variaveis server-side, nunca usar com NEXT_PUBLIC_.
PAYMENT_PROVIDER=asaas
PAYMENT_WEBHOOKS_ENABLED=false
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_URL=https://api-sandbox.asaas.com
ASAAS_API_KEY=SUA_CHAVE_ASAAS_APENAS_SERVER_SIDE
ASAAS_WEBHOOK_TOKEN=SEU_TOKEN_DE_WEBHOOK_ASAAS_APENAS_SERVER_SIDE